<Window x:Class="ADPhoneBook.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки подключения AD"
        Height="400" Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource LightBgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Настройки подключения"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,20"/>

        <!-- Форма -->
        <StackPanel Grid.Row="1">

            <!-- LDAP Path -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Style="{StaticResource LabelStyle}"
                           Text="LDAP путь (оставьте пустым для текущего домена)"/>
                <TextBox x:Name="TxtLdap"
                         Style="{StaticResource ModernTextBox}"
                         Text="{Binding LdapPath, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Пример: LDAP://DC=company,DC=local"/>
                <TextBlock Foreground="#8899AA" FontSize="10" Margin="0,3,0,0"
                           Text="Пример: LDAP://DC=company,DC=local  или  LDAP://192.168.1.10"/>
            </StackPanel>

            <!-- Текущий пользователь -->
            <CheckBox x:Name="ChkCurrentUser"
                      Content="Использовать текущего пользователя Windows (рекомендуется)"
                      IsChecked="{Binding UseCurrentUser}"
                      FontSize="13"
                      Margin="0,0,0,14"
                      Foreground="{StaticResource TextPrimaryBrush}"/>

            <!-- Логин -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Style="{StaticResource LabelStyle}" Text="Логин (домен\\пользователь или UPN)"/>
                <TextBox x:Name="TxtUser"
                         Style="{StaticResource ModernTextBox}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsNotCurrentUser}"
                         ToolTip="Пример: COMPANY\\john.doe  или  john.doe@company.local"/>
            </StackPanel>

            <!-- Пароль -->
            <StackPanel>
                <TextBlock Style="{StaticResource LabelStyle}" Text="Пароль"/>
                <PasswordBox x:Name="PwdBox"
                             IsEnabled="{Binding IsNotCurrentUser}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1.5"
                             Padding="10,7"
                             FontSize="13"/>
            </StackPanel>

        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                    Width="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Сохранить" Style="{StaticResource PrimaryButton}"
                    Width="120" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
