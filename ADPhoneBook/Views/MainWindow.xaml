<Window x:Class="ADPhoneBook.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ADPhoneBook.ViewModels"
        xmlns:conv="clr-namespace:ADPhoneBook.Converters"
        Title="Телефонная книга"
        Height="720" Width="1100"
        MinHeight="540" MinWidth="800"
        Background="{StaticResource LightBgBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <conv:StringToVisibilityConverter      x:Key="StrToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ШАПКА -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="8"
                            Background="#2980B9" Margin="0,0,12,0">
                        <TextBlock Text="&#x1F4DE;" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Телефонная книга" Foreground="White"
                                   FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Active Directory" Foreground="#8AAFCB" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="&#x2699; Настройки"
                        Command="{Binding OpenSettingsCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Background="Transparent" Foreground="White"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ПАНЕЛЬ ИНСТРУМЕНТОВ -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Padding="36,7,36,7"/>
                    <TextBlock Text="&#x1F50D;" FontSize="14"
                               VerticalAlignment="Center" Margin="10,0,0,0"
                               IsHitTestVisible="False"/>
                    <Button Content="&#x2715;" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,8,0"
                            Width="20" Height="20" FontSize="10"
                            Command="{Binding ClearSearchCommand}"
                            Visibility="{Binding SearchText, Converter={StaticResource StrToVis}}"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                    <TextBlock Text="Поиск по имени, отделу, телефону..."
                               Foreground="#AABBCC" FontSize="13"
                               VerticalAlignment="Center" Margin="36,0,0,0"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Фильтр по отделам -->
                <ComboBox Grid.Column="1" Margin="0,0,10,0"
                          ItemsSource="{Binding Departments}"
                          SelectedItem="{Binding SelectedDepartment}"
                          Style="{StaticResource ModernComboBox}"/>

                <!-- Excel -->
                <Button Grid.Column="2" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        Content="&#x1F4CA; Excel"
                        Command="{Binding ExportExcelCommand}"/>

                <!-- CSV -->
                <Button Grid.Column="3"
                        Style="{StaticResource SecondaryButton}"
                        Content="&#x1F4C4; CSV"
                        Command="{Binding ExportCsvCommand}"/>
            </Grid>
        </Border>

        <!-- КОНТЕНТ -->
        <Grid Grid.Row="2" Margin="16">

            <!-- Оверлей загрузки -->
            <Border Background="#CC1A3C5E" CornerRadius="8"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                    Panel.ZIndex="10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#x231B;" FontSize="40"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Загрузка данных из AD..." Foreground="White"
                               FontSize="16" HorizontalAlignment="Center"/>
                    <Button Content="Отменить" Margin="0,16,0,0"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelCommand}"
                            HorizontalAlignment="Center"
                            Background="Transparent" Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Таблица -->
            <Border CornerRadius="8" ClipToBounds="True"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <DataGrid ItemsSource="{Binding EmployeesView}"
                          SelectedItem="{Binding SelectedEmployee}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserReorderColumns="True"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#E8EEF4"
                          AlternationCount="2"
                          RowHeight="40"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          FontSize="13"
                          Background="White"
                          BorderThickness="0"
                          ColumnHeaderHeight="44">

                    <DataGrid.Columns>

                        <!-- ФИО с аватаром -->
                        <DataGridTemplateColumn Header="ФИО" Width="220" SortMemberPath="DisplayName">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="30" Height="30" CornerRadius="15"
                                                Background="#2980B9" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Initials}"
                                                       Foreground="White" FontSize="11" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Отдел"     Binding="{Binding Department}" Width="180"/>
                        <DataGridTextColumn Header="Должность" Binding="{Binding Title}"      Width="200"/>

                        <!-- Рабочий тел. -->
                        <DataGridTemplateColumn Header="Рабочий тел." Width="150" SortMemberPath="WorkPhone">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#x260E; " Foreground="#5A7285" FontSize="12"/>
                                        <TextBlock Text="{Binding WorkPhone}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Мобильный -->
                        <DataGridTemplateColumn Header="Мобильный" Width="150" SortMemberPath="MobilePhone">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#x1F4F1; " Foreground="#5A7285" FontSize="12"/>
                                        <TextBlock Text="{Binding MobilePhone}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Email -->
                        <DataGridTemplateColumn Header="Email" Width="*" SortMemberPath="Email">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#x2709; " Foreground="#5A7285" FontSize="12"/>
                                        <TextBlock Text="{Binding Email}"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                    <!-- Пустое состояние -->
                    <DataGrid.Style>
                        <Style TargetType="DataGrid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EmployeesView}" Value="{x:Null}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGrid">
                                                <Border Background="White">
                                                    <StackPanel HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="&#x1F4CB;" FontSize="48"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,0,0,16"/>
                                                        <TextBlock Text="Загрузка данных..."
                                                                   FontSize="16"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                </DataGrid>
            </Border>
        </Grid>

        <!-- СТРОКА СОСТОЯНИЯ -->
        <Border Grid.Row="3" Background="{StaticResource PrimaryBrush}" Padding="16,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#8AAFCB" FontSize="12" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
